PORT=3001
JWT_SECRET=roger_dev_secret_change_me
DB_PATH=backend/database/roger.sqlite
NODE_ENV=development

# Conexão Oracle MV
# O COSTA aceita os nomes abaixo e também os nomes antigos que você já vinha usando:
# ORACLE_USER / ORACLE_PASSWORD / ORACLE_CONNECT_STRING
# DB_USER / DB_PASSWORD / DB_CONNECT_STRING
# DB_USERNAME / DB_PASSWORD / DB_CONNECTION_STRING
# MV_USER / MV_PASSWORD / MV_CONNECT_STRING
MV_ORACLE_USER=
MV_ORACLE_PASSWORD=
MV_ORACLE_CONNECT_STRING=

# Opcional, somente se sua máquina precisar apontar o Instant Client manualmente
# ORACLE_CLIENT_LIB_DIR=C:\\oracle\\instantclient_21_13
