{
  "name": "roger-suite",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:frontend": "vite --host 0.0.0.0 --port 5173 --strictPort",
    "dev:backend": "nodemon backend/src/server.js",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0 --port 4173",
    "start:backend": "node backend/src/server.js",
    "start": "node backend/src/server.js",
    "prod": "npm run build && node backend/src/server.js"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "bcryptjs": "^3.0.2",
    "better-sqlite3": "^12.2.0",
    "concurrently": "^9.2.1",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^5.4.2",
    "oracledb": "^6.7.2"
  },
  "devDependencies": {
    "nodemon": "^3.1.10"
  }
}
